{
  "name": "jonganebski.github.io",
  "private": true,
  "description": "Blog and portfolio page",
  "version": "0.1.0",
  "license": "0BSD",
  "scripts": {
    "build": "gatsby build",
    "develop:gatsby": "env-cmd gatsby develop",
    "develop:type-check": "tsc --watch",
    "develop": "npm-run-all --parallel develop:gatsby develop:type-check",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "start": "npm run develop",
    "serve": "gatsby serve",
    "clean": "gatsby clean",
    "test": "echo \"Write tests! -> https://gatsby.dev/unit-testing\" && exit 1",
    "deploy": "gatsby build && gh-pages -d public -b gh-pages"
  },
  "dependencies": {
    "babel-plugin-styled-components": "^1.12.0",
    "gatsby": "^2.26.1",
    "gatsby-plugin-sharp": "^2.14.1",
    "gatsby-plugin-styled-components": "^3.10.0",
    "gatsby-plugin-web-font-loader": "^1.0.4",
    "gatsby-remark-images": "^3.11.0",
    "gatsby-remark-relative-images": "^2.0.2",
    "gatsby-source-filesystem": "^2.11.0",
    "gatsby-transformer-remark": "^2.16.0",
    "npm-run-all": "^4.1.5",
    "react": "^16.12.0",
    "react-dom": "^16.12.0",
    "styled-components": "^5.2.1",
    "styled-reset": "^4.3.4",
    "ts-node": "^9.1.1"
  },
  "devDependencies": {
    "@types/gatsby-transformer-remark": "^2.9.0",
    "@types/react": "^17.0.2",
    "@types/react-dom": "^17.0.1",
    "@types/styled-components": "^5.1.7",
    "env-cmd": "^10.1.0",
    "gh-pages": "^3.1.0",
    "prettier": "2.2.1",
    "typescript": "^4.1.5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jonganebski/jonganebski.github.io"
  },
  "bugs": {
    "url": "https://github.com/jonganebski/jonganebski.github.io/issues"
  }
}
