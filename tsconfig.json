{
    "compilerOptions": {
      "target": "es5",
      "module": "commonjs",
      "allowJs": true,
      "checkJs": true,
      "jsx": "react",
      "forceConsistentCasingInFileNames": true,
      "noImplicitReturns": true,
      "esModuleInterop": true,
      "strict": true,
      "skipLibCheck": true,
      "allowSyntheticDefaultImports": true,
      "noEmit": true,
      "pretty": true
    },
    "include": ["./src"],
    "exclude": ["./node_modules", "./public", "./.cache"],
  }