r(--grvsc-line-highlighted-background-color, rgba(0, 0, 0, 0.05));\n    box-shadow: inset var(--grvsc-line-highlighted-border-width, 4px) 0 0 0 var(--grvsc-line-highlighted-border-color, rgba(0, 0, 0, 0.2));\n  }\n  .wrapper[data-theme=dark] .grvsc-ps-tlfloc {\n    background-color: #1E1E1E;\n    color: #D4D4D4;\n  }\n  .wrapper[data-theme=dark] .grvsc-ps-tlfloc .grvsc-line-highlighted::before {\n    background-color: var(--grvsc-line-highlighted-background-color, rgba(255, 255, 255, 0.1));\n    box-shadow: inset var(--grvsc-line-highlighted-border-width, 4px) 0 0 0 var(--grvsc-line-highlighted-border-color, rgba(255, 255, 255, 0.5));\n  }\n</style>"}},"pageContext":{"slug":"2021-02-18","type":"blog","prevNode":{"frontmatter":{"title":"객체를 복사하는 방법, JSON.parse(JSON.stringify(Object)) vs 깊은 복사"},"timeToRead":6,"fields":{"slug":"2021-02-15","type":"blog"}},"nextNode":{"frontmatter":{"title":"Big O Notation"},"timeToRead":2,"fields":{"slug":"2021-02-26","type":"blog"}}}},"staticQueryHashes":[]}